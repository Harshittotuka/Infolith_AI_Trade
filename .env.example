PORT=5175
MARKET_PROVIDER=demo
# REST fallback interval (demo mode, or Upstox before the live feed connects).
POLL_INTERVAL_MS=15000
# Upstox live WebSocket feed mode: ltpc | full | option_greeks | full_d30.
# "full" gives price, change, volume, and open interest. Used only when MARKET_PROVIDER=upstox.
UPSTOX_FEED_MODE=full

# Upstox API
# Set MARKET_PROVIDER=upstox after creating an Upstox app.
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URL=http://localhost:5175/auth/upstox/callback
# Optional: paste a current access token here instead of using the login route.
UPSTOX_ACCESS_TOKEN=

# Email alerts through any SMTP provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_TO=

# Telegram phone notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMS alerts. Choose: twilio or msg91.
SMS_PROVIDER=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# MSG91 Flow API. Your DLT/flow template should include a variable named message.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_TO_MOBILE=

# Optional generic webhook for Make, Zapier, IFTTT, Discord relay, etc.
NOTIFY_WEBHOOK_URL=
